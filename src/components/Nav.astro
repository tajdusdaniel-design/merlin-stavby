---
const navLinks = [
  { href: '/sluzby', label: 'Služby' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/recenze', label: 'Recenze' },
  { href: '/kontakt', label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Merlin Stavby – domovská stránka">
      <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 600" aria-hidden="true" focusable="false">
        <g fill="currentColor">
          <path d="M 90 500 L 560 70 L 665 165 L 940 165 L 940 70 L 1045 70 L 1045 165 L 1220 165 L 1510 500 L 900 500 L 560 190 L 190 500 Z"/>
          <rect x="445" y="365" width="82" height="68"/>
          <rect x="575" y="365" width="82" height="68"/>
          <rect x="445" y="465" width="82" height="68"/>
          <rect x="575" y="465" width="82" height="68"/>
        </g>
      </svg>
      <span class="logo-text">Merlin <strong>Stavby</strong></span>
    </a>

    <nav class="nav-desktop" aria-label="Hlavní navigace">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/kontakt" class="btn btn-primary">Nezávazná poptávka</a>
    </div>

    <button class="nav-toggle" aria-label="Otevřít menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="bar bar--top"></span>
      <span class="bar bar--mid"></span>
      <span class="bar bar--bot"></span>
    </button>
  </div>

  <!-- mobile-menu je display:grid; výška animována přes grid-template-rows -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <nav aria-label="Mobilní navigace">
        <ul class="mobile-nav-list">
          <li><a href="/" class:list={['mobile-nav-link', { 'mobile-nav-link--active': currentPath === '/' }]}>Domů</a></li>
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={['mobile-nav-link', { 'mobile-nav-link--active': currentPath.startsWith(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mobile-menu-footer">
          <a href="/kontakt" class="btn btn-primary" style="width:100%; justify-content:center;">Nezávazná poptávka</a>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
/* ── Header ─────────────────────────────────────────────── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
}

.header-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 68px;
}

/* ── Logo ────────────────────────────────────────────────── */
.logo {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  flex-shrink: 0;
}

.logo-icon {
  height: 28px;
  width: auto;
  display: block;
  color: #0A0A0A;
  flex-shrink: 0;
}

.logo-text {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.logo-text strong {
  font-weight: 700;
  color: var(--color-primary);
}

/* ── Desktop nav ─────────────────────────────────────────── */
.nav-desktop { margin-left: auto; }

.nav-list {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.nav-link {
  padding: 0.375rem 0.75rem;
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-text-muted);
  border-radius: var(--radius-sm);
  transition: color 180ms ease, background-color 180ms ease;
}

.nav-link:hover {
  color: var(--color-primary);
  background-color: var(--color-surface);
}

.nav-link--active {
  color: var(--color-primary);
  font-weight: 600;
}

/* ── Header actions ──────────────────────────────────────── */
.header-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-shrink: 0;
}


/* ── Hamburger ───────────────────────────────────────────── */
.nav-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  border-radius: var(--radius-sm);
}

.bar {
  display: block;
  height: 2px;
  background-color: var(--color-text-primary);
  border-radius: 2px;
  transform-origin: center;
  transition:
    transform 280ms cubic-bezier(0.23, 1, 0.32, 1),
    opacity   180ms ease;
}

/* X animace */
.nav-toggle[aria-expanded="true"] .bar--top {
  transform: translateY(7px) rotate(45deg);
}
.nav-toggle[aria-expanded="true"] .bar--mid {
  opacity: 0;
  transform: scaleX(0);
}
.nav-toggle[aria-expanded="true"] .bar--bot {
  transform: translateY(-7px) rotate(-45deg);
}

/* ── Mobile menu — skryto na desktopu, animace jen na mobilu ── */
.mobile-menu {
  display: none;
}

@media (max-width: 900px) {
  .mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    background-color: var(--color-bg);
    border-top: 1px solid transparent;
    overflow: hidden;
    transition:
      grid-template-rows 320ms cubic-bezier(0.23, 1, 0.32, 1),
      border-top-color   320ms ease;
  }

  .mobile-menu.is-open {
    grid-template-rows: 1fr;
    border-top-color: var(--color-border);
  }
}

.mobile-menu-inner {
  overflow: hidden;
  min-height: 0; /* nutné pro grid collapse */
  padding: 1.25rem 1.5rem 1.5rem;
}

.mobile-nav-list {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
  margin-bottom: 1.25rem;
}

.mobile-nav-link {
  display: block;
  padding: 0.75rem 1rem;
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-text-muted);
  border-radius: var(--radius-md);
  transition: background-color 180ms ease, color 180ms ease;
  /* výchozí stav pro stagger */
  opacity: 0;
  transform: translateY(-6px);
}

.mobile-nav-link:hover,
.mobile-nav-link--active {
  background-color: var(--color-surface);
  color: var(--color-primary);
}

/* stagger fade-in při otevření */
@keyframes navItemIn {
  to { opacity: 1; transform: translateY(0); }
}

.mobile-menu.is-open .mobile-nav-list li:nth-child(1) .mobile-nav-link { animation: navItemIn 220ms cubic-bezier(0.23, 1, 0.32, 1) 60ms forwards; }
.mobile-menu.is-open .mobile-nav-list li:nth-child(2) .mobile-nav-link { animation: navItemIn 220ms cubic-bezier(0.23, 1, 0.32, 1) 90ms forwards; }
.mobile-menu.is-open .mobile-nav-list li:nth-child(3) .mobile-nav-link { animation: navItemIn 220ms cubic-bezier(0.23, 1, 0.32, 1) 120ms forwards; }
.mobile-menu.is-open .mobile-nav-list li:nth-child(4) .mobile-nav-link { animation: navItemIn 220ms cubic-bezier(0.23, 1, 0.32, 1) 150ms forwards; }
.mobile-menu.is-open .mobile-nav-list li:nth-child(5) .mobile-nav-link { animation: navItemIn 220ms cubic-bezier(0.23, 1, 0.32, 1) 180ms forwards; }

.mobile-menu-footer {
  opacity: 0;
  transform: translateY(-4px);
}
.mobile-menu.is-open .mobile-menu-footer {
  animation: navItemIn 220ms cubic-bezier(0.23, 1, 0.32, 1) 210ms forwards;
}

/* ── Responsive ──────────────────────────────────────────── */
@media (max-width: 900px) {
  .nav-desktop,
  .header-actions {
    display: none;
  }

  .nav-toggle {
    display: flex;
    margin-left: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  .mobile-menu {
    transition: none;
  }
  .mobile-nav-link,
  .mobile-menu-footer {
    opacity: 1;
    transform: none;
    animation: none !important;
  }
}
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Otevřít menu' : 'Zavřít menu');
    menu?.classList.toggle('is-open');
    menu?.setAttribute('aria-hidden', String(isOpen));
  });

  /* Zavřít při resize na desktop */
  const mq = window.matchMedia('(min-width: 901px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) {
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('is-open');
      menu?.setAttribute('aria-hidden', 'true');
    }
  });
</script>
