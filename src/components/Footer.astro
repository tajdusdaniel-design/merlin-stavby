<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo" aria-label="Merlin Stavby">
        <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 600" aria-hidden="true" focusable="false">
          <g fill="currentColor">
            <path d="M 90 500 L 560 70 L 665 165 L 940 165 L 940 70 L 1045 70 L 1045 165 L 1220 165 L 1510 500 L 900 500 L 560 190 L 190 500 Z"/>
            <rect x="445" y="365" width="82" height="68"/>
            <rect x="575" y="365" width="82" height="68"/>
            <rect x="445" y="465" width="82" height="68"/>
            <rect x="575" y="465" width="82" height="68"/>
          </g>
        </svg>
        <span class="logo-text">Merlin <strong>Stavby</strong></span>
      </a>
      <p class="footer-tagline">Stavba a rekonstrukce, u které pořád víte, co se děje.</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <p class="footer-col-title">Služby</p>
        <ul>
          <li><a href="/sluzby/novostavby">Novostavby</a></li>
          <li><a href="/sluzby/rekonstrukce">Rekonstrukce</a></li>
          <li><a href="/sluzby/dilci-stavebni-cinnost">Dílčí stavební činnost</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Web</p>
        <ul>
          <li><a href="/galerie">Galerie</a></li>
          <li><a href="/recenze">Recenze</a></li>
          <li><a href="/kontakt">Kontakt</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Kontakt</p>
        <ul>
          <li><a href="tel:+420702810121">702 810 121</a></li>
          <li><a href="mailto:info@merlinstavby.cz">info@merlinstavby.cz</a></li>
          <li>
            <a href="https://www.instagram.com/merlinstavby" target="_blank" rel="noopener">Instagram</a>
          </li>
          <li>
            <a href="https://www.facebook.com/merlinstavbysro" target="_blank" rel="noopener">Facebook</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-legal">
        Merlin stavby s.r.o. &middot; Jiřího Herolda 1559/10, 700 30 Ostrava &middot; IČ 17133921
      </p>
      <div class="footer-copy-wrap">
        <p class="footer-credit">
          Vytvořeno · <a href="https://danieltajdus.cz" target="_blank" rel="noopener">Daniel Tajduš</a>
        </p>
        <p class="footer-copy">
          &copy; <span id="footer-year"></span> Merlin stavby s.r.o.
        </p>
      </div>
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<style>
.site-footer {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
  margin-top: auto;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 4rem;
  padding-block: 4rem;
}

/* Brand */
.footer-brand .logo {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  margin-bottom: 1rem;
}

.footer-brand .logo-icon {
  height: 28px;
  width: auto;
  display: block;
  color: white;
  flex-shrink: 0;
}

.footer-brand .logo-text {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 500;
  color: white;
}

.footer-brand .logo-text strong {
  font-weight: 700;
  color: white;
}

.footer-tagline {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
  max-width: 28ch;
}

/* Links */
.footer-links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.footer-col-title {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 1rem;
}

.footer-col ul {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.footer-col a {
  font-size: 0.9375rem;
  color: rgba(255,255,255,0.8);
  transition: color var(--transition);
}

.footer-col a:hover {
  color: white;
}

/* Bottom bar */
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
}

.footer-bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-block: 1.25rem;
  gap: 1rem;
}

.footer-legal,
.footer-copy {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.45);
}

.footer-copy-wrap {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

.footer-credit {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.35);
}

.footer-credit a {
  color: rgba(255,255,255,0.5);
  transition: color var(--transition);
}

.footer-credit a:hover {
  color: rgba(255,255,255,0.85);
}

@media (max-width: 900px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: 3rem;
  }

  .footer-links {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 540px) {
  .footer-links {
    grid-template-columns: 1fr;
  }

  .footer-bottom-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>
