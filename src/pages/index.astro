---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import imgKoupMramor from '../assets/images/real-koupelna-mramor.jpg';
import imgKuchBila    from '../assets/images/real-kuchyn-bila.jpg';
import imgKuchLed     from '../assets/images/real-kuchyn-led.jpg';
import imgKoupTmava   from '../assets/images/real-koupelna-tmava.jpg';
import imgKuchModra   from '../assets/images/real-kuchyn-modra.jpg';
import imgChodba      from '../assets/images/real-chodba-bila.jpg';

const services = [
  { number: '01', title: 'Novostavby', text: 'Dům na klíč, hrubá stavba, základová deska i navázání na rozpracovanou část. Koordinaci řešíme za vás.', href: '/sluzby/novostavby' },
  { number: '02', title: 'Rekonstrukce', text: 'Byt, dům, jádro, podlahy, sádrokartony i povrchy. Od bourání po předání hotového prostoru.', href: '/sluzby/rekonstrukce' },
  { number: '03', title: 'Dílčí práce', text: 'Pergoly, přístřešky, dlažby a konkrétní stavební práce bez zbytečně velké zakázky.', href: '/sluzby/dilci-stavebni-cinnost' },
  { number: '04', title: 'Sádrokartony', text: 'Příčky, podhledy a konstrukce, které navážou na zbytek stavby a budou připravené na finální povrchy.', href: '/sluzby/rekonstrukce' },
  { number: '05', title: 'Podlahy', text: 'Příprava podkladu, pokládka a dokončení podlah tak, aby výsledek seděl technicky i vizuálně.', href: '/sluzby/rekonstrukce' },
  { number: '06', title: 'Pergoly a dlažby', text: 'Venkovní úpravy kolem domu, které mají být hotové čistě, pevně a bez dlouhého čekání.', href: '/sluzby/dilci-stavebni-cinnost' },
];

const homeGallery = [
  { src: imgKoupMramor, alt: 'Koupelna s mramorovým obkladem' },
  { src: imgKuchBila,   alt: 'Bílá kuchyňská linka' },
  { src: imgKuchLed,    alt: 'Kuchyně s LED osvětlením' },
  { src: imgKoupTmava,  alt: 'Moderní tmavá koupelna' },
  { src: imgKuchModra,  alt: 'Kuchyně v šedé barvě' },
  { src: imgChodba,     alt: 'Dokončená chodba' },
];
---

<Layout
  title="Stavba a rekonstrukce"
  description="Postavíme nový dům nebo zrekonstruujeme ten váš. Budete vědět, kdy bude hotovo, co to stojí a jak práce pokračuje."
>
  <Nav slot="header" />

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Stavební firma · Ostrava &amp; Frýdek-Místek</p>
        <h1>Stavba a rekonstrukce, u které pořád víte, co se děje</h1>
        <p class="hero-sub">
          Postavíme nový dům nebo zrekonstruujeme ten váš — od demolice po nastěhování.
          Budete vědět, kdy bude hotovo, co to stojí a jak práce pokračuje. I když zrovna
          nejste na místě. Nemusíte nás hlídat. To je naše práce, ne vaše.
        </p>
        <div class="hero-ctas">
          <a href="/kontakt" class="btn btn-primary">Poptat rekonstrukci</a>
          <a href="/sluzby" class="btn btn-outline">Prohlédnout služby</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TRUST BAR ─────────────────────────────────────── -->
  <div class="trust-bar">
    <div class="container">
      <div class="trust-bar-inner">
        <div class="trust-bar-item">
          <span class="trust-bar-num">20+</span>
          <span class="trust-bar-label">let zkušeností</span>
        </div>
        <div class="trust-bar-divider" aria-hidden="true"></div>
        <div class="trust-bar-item">
          <span class="trust-bar-num">MSK</span>
          <span class="trust-bar-label">Moravskoslezský kraj</span>
        </div>
        <div class="trust-bar-divider" aria-hidden="true"></div>
        <div class="trust-bar-item">
          <span class="trust-bar-num">📷</span>
          <span class="trust-bar-label">Fotky z postupu</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── KDO JSME ──────────────────────────────────────── -->
  <section class="section section--large">
    <div class="container about-grid">
      <div class="about-content">
        <h2>Kdo jsme</h2>
        <p>
          Jsme stavební firma z Ostravy. Náš tým má za sebou přes 20 let praxe — od rekonstrukcí
          bytů po stavby celých domů. Za tu dobu jsme se naučili jednu věc: na stavbě nerozhoduje
          jen to, co umíte postavit, ale jestli držíte slovo. Co domluvíme, to platí.
          Spolupracujeme jen s řemeslníky, které známe a kterým věříme, protože dobrá práce
          je vždycky o lidech.
        </p>
      </div>
      <div class="about-stats-vert">
        <div class="about-stat-item">
          <span class="about-stat-num">20+</span>
          <span class="about-stat-label">let praxe týmu</span>
        </div>
        <div class="about-stat-item">
          <span class="about-stat-num">MSK</span>
          <span class="about-stat-label">kraj působení</span>
        </div>
        <div class="about-stat-item">
          <span class="about-stat-num">1</span>
          <span class="about-stat-label">kontakt po celou dobu</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SLUŽBY ────────────────────────────────────────── -->
  <section class="section section--large section--surface services-section">
    <div class="container">
      <div class="section-top">
        <p class="section-kicker">Naše služby</p>
        <h2>Co u nás <span>zařídíte</span></h2>
      </div>

      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-number">{service.number}</div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </article>
        ))}
      </div>

      <div class="services-cta">
        <a href="/sluzby" class="btn btn-outline">Prohlédnout služby</a>
      </div>

      <div class="mission-panel" style="background-image: linear-gradient(90deg, rgba(7,20,38,0.10), rgba(7,20,38,0.32)), url('/images/service-dilci-pergola.jpg');">
        <div class="mission-card">
          <p class="section-kicker">Náš přístup</p>
          <h3>Držet <span>domluvu</span> a ukazovat postup práce.</h3>
          <p>Na stavbě nemá být chaos. Domluvíme rozsah, průběžně dokumentujeme postup a držíme jeden jasný kontakt po celou dobu.</p>
          <a href="/kontakt" class="btn btn-outline">Nezávazná poptávka</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── GALERIE TEASER ────────────────────────────────── -->
  <section class="section section--large">
    <div class="container">
      <div class="section__header text-center">
        <h2>Jak naše práce vypadá v praxi</h2>
        <p class="section__lead">
          Každou zakázku průběžně fotíme — nejen pro sebe, ale hlavně pro vás. Můžete být klidně
          na dovolené a pořád vidíte, kam se stavba posunula.
        </p>
      </div>
      <div class="gallery-grid">
        {homeGallery.map((image, i) => (
          <button class="gallery-thumb-btn" data-index={i} aria-label={`Zobrazit foto: ${image.alt}`}>
            <Image src={image.src} alt={image.alt} class="site-photo gallery-thumb" width={600} format="webp" quality={75} loading="eager" decoding="async" />
          </button>
        ))}
      </div>
      <div class="gallery-cta">
        <a href="/galerie" class="btn btn-outline">Celá galerie</a>
      </div>
    </div>
  </section>

  <!-- ── LIGHTBOX ──────────────────────────────────────── -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Galerie" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Zavřít">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox-arrow lightbox-prev" id="lightbox-prev" aria-label="Předchozí foto">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <button class="lightbox-arrow lightbox-next" id="lightbox-next" aria-label="Další foto">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <!-- ── RECENZE TEASER ────────────────────────────────── -->
  <section class="section section--medium reviews-section">
    <div class="container">
      <div class="section__header">
        <h2>Co o nás říkají zákazníci</h2>
        <p class="section__lead">Reference od lidí, pro které jsme stavěli nebo rekonstruovali.</p>
      </div>
    </div>

    <div class="reviews-carousel" role="region" aria-label="Reference zákazníků">
      <div class="reviews-carousel__track">
        {[
          { initials: 'PH', name: 'Petr H.', role: 'Ostrava', text: 'Rekonstrukci bytu 3+1 zvládli přesně v termínu, na kterém jsme se domluvili. Co mě nejvíc překvapilo — celou dobu jsem věděl, v jaké fázi jsme, protože nám pravidelně posílali fotky. Žádné hádání, kdy přijdou.' },
          { initials: 'LT', name: 'Lucie a Tomáš M.', role: 'Frýdek-Místek', text: 'Hledali jsme firmu na celou rekonstrukci domu a báli jsme se, že to bude boj. Nakonec úplný opak. Domluva platila, cena se nezměnila a když jsme něco potřebovali doladit i po předání, vyřešili to bez řečí.' },
          { initials: 'JK', name: 'Jan K.', role: 'Brušperk', text: 'Stavěli nám hrubou stavbu rodinného domu. Pracovalo se každý den, nemuseli jsme nikoho honit. Konečně firma, na kterou je spoleh.' },
          { initials: 'MN', name: 'Miroslava N.', role: 'Opava', text: 'Měla jsem špatné zkušenosti s předchozí firmou, takže jsem šla do toho s obavami. Tady bylo vše jinak — přišli v domluvený den, průběžně informovali a výsledek předčil očekávání.' },
          { initials: 'RV', name: 'Radek V.', role: 'Ostrava-Poruba', text: 'Pergola i dlažba na terase hotová v jednom týdnu. Přesně jak jsme se domluvili, bez táhání a výmluv. Cena odpovídala nabídce.' },
        ].flatMap(r => [r, r]).map(r => (
          <div class="reviews-carousel__card" data-placeholder="true">
            <div class="reviews-carousel__quote" aria-hidden="true">&ldquo;</div>
            <p class="reviews-carousel__text">{r.text}</p>
            <div class="reviews-carousel__author">
              <div class="reviews-carousel__avatar" aria-hidden="true">{r.initials}</div>
              <div>
                <p class="reviews-carousel__name">{r.name}</p>
                <p class="reviews-carousel__role">{r.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="container">
      <div class="testimonials-cta">
        <a href="/recenze" class="btn btn-outline">Zobrazit reference</a>
      </div>
    </div>
  </section>

  <!-- ── FINÁLNÍ CTA ───────────────────────────────────── -->
  <section class="section section--compact cta-section">
    <div class="container">
      <div class="cta-block">
        <h2>Plánujete stavbu nebo rekonstrukci?</h2>
        <p>
          Přijedeme se podívat, v klidu probereme, co potřebujete, a řekneme vám, jak by to šlo.
          Nezávazně a zdarma.
        </p>
        <div class="cta-actions">
          <a href="/kontakt" class="btn btn-primary cta-btn">Nezávazná poptávka</a>
          <a href="/kontakt" class="btn btn-outline cta-btn">Kontaktovat</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: clamp(640px, 86svh, 760px);
  display: grid;
  place-items: center;
  padding-block: 5rem;
  overflow: hidden;
  background-image:
    linear-gradient(rgba(7, 20, 38, 0.42), rgba(7, 20, 38, 0.52)),
    url('/images/hero-kitchen-background.webp');
  background-size: cover;
  background-position: center;
}

.hero-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-content {
  max-width: 860px;
  margin-inline: auto;
  text-align: center;
}

.hero-eyebrow {
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.82);
  margin-bottom: 1.25rem;
}

.hero-content h1 {
  color: white;
  margin-bottom: 1.5rem;
  text-wrap: balance;
  text-shadow: 0 2px 24px rgba(0, 0, 0, 0.5);
}

.hero-sub {
  font-size: 1.125rem;
  font-weight: 500;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.9);
  max-width: 62ch;
  margin: 0 auto 2.5rem;
  text-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
}

.hero-ctas {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.hero .btn-outline {
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(255, 255, 255, 0.38);
  color: white;
  backdrop-filter: blur(16px) saturate(160%);
  -webkit-backdrop-filter: blur(16px) saturate(160%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
  transition:
    background  180ms ease,
    border-color 180ms ease,
    box-shadow   180ms ease,
    transform    160ms cubic-bezier(0.23, 1, 0.32, 1);
}

.hero .btn-outline:hover {
  background: rgba(255, 255, 255, 0.20);
  border-color: rgba(255, 255, 255, 0.6);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.28);
}

.hero .btn-outline:active {
  transform: scale(0.97);
}

.hero .btn-primary:active {
  transform: scale(0.97);
}

/* ── Trust Bar ────────────────────────────────────────── */
.trust-bar {
  background-color: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  padding-block: 1.25rem;
}

.trust-bar-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}

.trust-bar-item {
  display: flex;
  align-items: center;
  gap: 0.625rem;
}

.trust-bar-num {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-primary);
}

.trust-bar-label {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-muted);
}

.trust-bar-divider {
  width: 1px;
  height: 1.5rem;
  background-color: var(--color-border);
}

/* ── Kdo jsme ─────────────────────────────────────────── */
.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  align-items: start;
  gap: 5rem;
}

.about-content h2 {
  margin-bottom: 1.25rem;
}

.about-content p {
  line-height: 1.75;
}

.about-stats-vert {
  display: flex;
  flex-direction: column;
}

.about-stat-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 1.375rem 0;
  border-bottom: 1px solid var(--color-border);
}

.about-stat-item:first-child {
  padding-top: 0;
}

.about-stat-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.about-stat-num {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.about-stat-label {
  font-size: 0.8125rem;
  color: var(--color-text-muted);
}

/* ── Služby grid ──────────────────────────────────────── */
.services-section {
  background-color: var(--color-surface);
}

.section-top {
  text-align: center;
  margin-bottom: 4rem;
}

.section-kicker {
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: 0.75rem;
}

.section-top h2 span,
.mission-card h3 span {
  color: var(--color-accent);
}

.section-link {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary);
  transition: gap var(--transition), color var(--transition);
}

.section-link:hover {
  gap: 0.625rem;
  color: var(--color-accent);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rem 3rem;
}

.service-card {
  min-height: 172px;
  padding-left: 2rem;
  border-left: 1px solid rgba(20, 33, 61, 0.14);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.service-number {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--color-accent);
  margin-bottom: 0.8rem;
}

.service-card h3 {
  font-size: clamp(1.3rem, 2vw, 1.75rem);
  max-width: 11ch;
  margin-bottom: 0.75rem;
}

.service-card p {
  font-size: 0.875rem;
  line-height: 1.55;
  max-width: 28ch;
}

.services-cta {
  margin-top: 3.5rem;
  text-align: center;
}

.mission-panel {
  position: relative;
  margin-top: 4rem;
  min-height: 430px;
  border-radius: 22px;
  overflow: hidden;
  background-image: linear-gradient(90deg, rgba(7,20,38,0.10), rgba(7,20,38,0.32)), url('/images/service-novostavby.webp');
  background-size: cover;
  background-position: center;
}

.mission-card {
  position: absolute;
  left: 2rem;
  bottom: 2rem;
  width: min(520px, calc(100% - 4rem));
  padding: 2.25rem;
  background-color: #fff;
  border-radius: 18px;
  box-shadow: 0 24px 60px rgba(20, 33, 61, 0.18);
}

.mission-card h3 {
  font-size: clamp(1.7rem, 3vw, 2.35rem);
  margin-bottom: 1rem;
}

.mission-card p:not(.section-kicker) {
  font-size: 0.95rem;
  max-width: 52ch;
  margin-bottom: 1.5rem;
}

/* ── Galerie ──────────────────────────────────────────── */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.gallery-thumb-btn {
  all: unset;
  display: block;
  cursor: pointer;
  border-radius: 14px;
  overflow: hidden;
  transition: opacity var(--transition);
}

.gallery-thumb-btn:hover {
  opacity: 0.88;
}

.gallery-thumb {
  aspect-ratio: 3/4;
  width: 100%;
  object-fit: cover;
  display: block;
  border-radius: 0;
}

.gallery-cta {
  margin-top: 2.5rem;
  text-align: center;
}

/* ── Lightbox ─────────────────────────────────────────── */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background-color: rgba(7, 20, 38, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.lightbox[hidden] {
  display: none;
}

.lightbox-img {
  max-width: 100%;
  max-height: 85vh;
  object-fit: contain;
  border-radius: 8px;
  display: block;
}

.lightbox-close {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  background: rgba(255,255,255,0.12);
  border: none;
  color: white;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color var(--transition);
}

.lightbox-close:hover {
  background: rgba(255,255,255,0.22);
}

.lightbox-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.12);
  border: none;
  color: white;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color var(--transition);
}

.lightbox-arrow:hover {
  background: rgba(255,255,255,0.22);
}

.lightbox-prev { left: 1.25rem; }
.lightbox-next { right: 1.25rem; }

/* ── Recenze carousel ─────────────────────────────────── */
.reviews-carousel {
  --c-edge: max(4vw, calc((100vw - 1200px) / 2));
  width: 100%;
  overflow: hidden;
  touch-action: pan-y;
  cursor: grab;
  -webkit-mask-image: linear-gradient(
    to right,
    transparent var(--c-edge),
    #000 calc(var(--c-edge) + 160px),
    #000 calc(100% - var(--c-edge) - 160px),
    transparent calc(100% - var(--c-edge))
  );
  mask-image: linear-gradient(
    to right,
    transparent var(--c-edge),
    #000 calc(var(--c-edge) + 160px),
    #000 calc(100% - var(--c-edge) - 160px),
    transparent calc(100% - var(--c-edge))
  );
  margin-top: 2rem;
}
