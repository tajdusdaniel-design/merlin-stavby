---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  { number: '01', title: 'Novostavby', text: 'Dům na klíč, hrubá stavba, základová deska i navázání na rozpracovanou část. Koordinaci řešíme za vás.', href: '/sluzby/novostavby' },
  { number: '02', title: 'Rekonstrukce', text: 'Byt, dům, jádro, podlahy, sádrokartony i povrchy. Od bourání po předání hotového prostoru.', href: '/sluzby/rekonstrukce' },
  { number: '03', title: 'Dílčí práce', text: 'Pergoly, přístřešky, dlažby a konkrétní stavební práce bez zbytečně velké zakázky.', href: '/sluzby/dilci-stavebni-cinnost' },
  { number: '04', title: 'Sádrokartony', text: 'Příčky, podhledy a konstrukce, které navážou na zbytek stavby a budou připravené na finální povrchy.', href: '/sluzby/rekonstrukce' },
  { number: '05', title: 'Podlahy', text: 'Příprava podkladu, pokládka a dokončení podlah tak, aby výsledek seděl technicky i vizuálně.', href: '/sluzby/rekonstrukce' },
  { number: '06', title: 'Pergoly a dlažby', text: 'Venkovní úpravy kolem domu, které mají být hotové čistě, pevně a bez dlouhého čekání.', href: '/sluzby/dilci-stavebni-cinnost' },
];


const homeGallery = [
  { src: '/images/gallery-kuchyn-svetla.webp', alt: 'Světlá kuchyň po rekonstrukci' },
  { src: '/images/gallery-kuchyn-bila.webp', alt: 'Bílá kuchyňská linka po dokončení' },
  { src: '/images/gallery-koupelna-sprcha.webp', alt: 'Koupelna se sprchovým koutem' },
  { src: '/images/gallery-koupelna-stresni.webp', alt: 'Rekonstrukce koupelny v podkroví' },
  { src: '/images/gallery-chodba.webp', alt: 'Dokončená chodba v interiéru' },
  { src: '/images/gallery-kuchyn-seda.webp', alt: 'Šedá kuchyň po rekonstrukci' },
];
---

<Layout
  title="Stavba a rekonstrukce"
  description="Postavíme nový dům nebo zrekonstruujeme ten váš. Budete vědět, kdy bude hotovo, co to stojí a jak práce pokračuje."
>
  <Nav slot="header" />

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Stavební firma · Ostrava &amp; Frýdek-Místek</p>
        <h1>Stavba a rekonstrukce, u které pořád víte, co se děje</h1>
        <p class="hero-sub">
          Postavíme nový dům nebo zrekonstruujeme ten váš — od demolice po nastěhování.
          Budete vědět, kdy bude hotovo, co to stojí a jak práce pokračuje. I když zrovna
          nejste na místě. Nemusíte nás hlídat. To je naše práce, ne vaše.
        </p>
        <div class="hero-ctas">
          <a href="/kontakt" class="btn btn-primary">Poptat rekonstrukci</a>
          <a href="/sluzby" class="btn btn-outline">Prohlédnout služby</a>
        </div>

        <div class="hero-trust">
          <div class="hero-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            20+ let zkušeností
          </div>
          <span class="hero-trust-sep" aria-hidden="true"></span>
          <div class="hero-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            Moravskoslezský kraj
          </div>
          <span class="hero-trust-sep" aria-hidden="true"></span>
          <div class="hero-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            Fotky z průběhu prací
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── KDO JSME ──────────────────────────────────────── -->
  <section class="section">
    <div class="container about-grid">
      <div class="about-images">
        <img src="/images/about-stavba.webp" alt="Tesařská práce u domu" class="site-photo about-img about-img--big" loading="lazy" decoding="async" />
        <img src="/images/about-detail.webp" alt="Detail dokončené koupelny" class="site-photo about-img about-img--small" loading="lazy" decoding="async" />
      </div>
      <div class="about-content">
        <h2>Kdo jsme</h2>
        <p>
          Jsme stavební firma z Ostravy. Náš tým má za sebou přes 20 let praxe — od rekonstrukcí
          bytů po stavby celých domů. Za tu dobu jsme se naučili jednu věc: na stavbě nerozhoduje
          jen to, co umíte postavit, ale jestli držíte slovo. Co domluvíme, to platí.
          Spolupracujeme jen s řemeslníky, které známe a kterým věříme, protože dobrá práce
          je vždycky o lidech.
        </p>
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat-num">20+</span>
            <span class="about-stat-label">let praxe týmu</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">MSK</span>
            <span class="about-stat-label">kraj působení</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">1</span>
            <span class="about-stat-label">kontakt po celou dobu</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SLUŽBY ────────────────────────────────────────── -->
  <section class="section section--surface services-section">
    <div class="container">
      <div class="section-top">
        <div>
          <p class="section-kicker">Naše služby</p>
          <h2>Co u nás <span>zařídíte</span></h2>
        </div>
        <a href="/sluzby" class="section-link">Prohlédnout služby
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-number">{service.number}</div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
            <a href={service.href} class="service-link">Zjistit více
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>

      <div class="mission-panel">
        <img src="/images/service-novostavby.webp" alt="Dřevěná pergola a venkovní stavební práce" class="mission-image" loading="eager" decoding="async" />
        <div class="mission-card">
          <p class="section-kicker">Náš přístup</p>
          <h3>Držet <span>domluvu</span> a ukazovat postup práce.</h3>
          <p>Na stavbě nemá být chaos. Domluvíme rozsah, průběžně dokumentujeme postup a držíme jeden jasný kontakt po celou dobu.</p>
          <a href="/kontakt" class="mission-link">Nezávazná poptávka
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── GALERIE TEASER ────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Jak naše práce vypadá v praxi</h2>
        <p class="section__lead">
          Každou zakázku průběžně fotíme — nejen pro sebe, ale hlavně pro vás. Můžete být klidně
          na dovolené a pořád vidíte, kam se stavba posunula.
        </p>
      </div>
      <div class="gallery-grid">
        {homeGallery.map((image) => (
          <img src={image.src} alt={image.alt} class="site-photo gallery-thumb" loading="eager" decoding="async" />
        ))}
      </div>
      <div class="gallery-cta">
        <a href="/galerie" class="btn btn-outline">Zobrazit galerii</a>
      </div>
    </div>
  </section>

  <!-- ── PROČ MERLIN ───────────────────────────────────── -->
  <section class="section section--surface">
    <div class="container">
      <div class="section__header text-center">
        <h2>Co tím získáte</h2>
      </div>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Pořád víte, co se děje</h3>
          <p>
            Postup vám dokumentujeme. Žádné týdny ticha, kdy netušíte, jestli se vůbec něco děje.
            Otevřete telefon a vidíte, jak stavba pokračuje.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
          <h3>Dostanete to, co bylo domluvené</h3>
          <p>
            Stavíme podle projektu a podle něj volíme i materiál. Na čem se domluvíme na začátku,
            to platí na konci. Bez překvapení na faktuře.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Řemeslníky hlídáme my, ne vy</h3>
          <p>
            Spolupracujeme jen s lidmi, které známe a kterým věříme. Nemusíte chodit na stavbu
            kontrolovat, jestli se pracuje. To je naše starost.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          </div>
          <h3>Předáním to nekončí</h3>
          <p>
            Když se po dokončení objeví cokoliv k doladění, ozvěte se. Nezmizíme ve chvíli,
            kdy je zaplaceno.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── RECENZE TEASER ────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Co o nás říkají zákazníci</h2>
        <p class="section__lead">Reference od lidí, pro které jsme stavěli nebo rekonstruovali.</p>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card" data-placeholder="true">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">
            Rekonstrukci bytu 3+1 zvládli přesně v termínu, na kterém jsme se domluvili.
            Co mě nejvíc překvapilo — celou dobu jsem věděl, v jaké fázi jsme, protože nám
            pravidelně posílali fotky. Žádné hádání, kdy přijdou.
          </p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">PH</div>
            <div>
              <p class="testimonial-name">Petr H.</p>
              <p class="testimonial-role">Ostrava</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-placeholder="true">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">
            Hledali jsme firmu na celou rekonstrukci domu a báli jsme se, že to bude boj.
            Nakonec úplný opak. Domluva platila, cena se nezměnila a když jsme něco potřebovali
            doladit i po předání, vyřešili to bez řečí.
          </p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">LT</div>
            <div>
              <p class="testimonial-name">Lucie a Tomáš M.</p>
              <p class="testimonial-role">Frýdek-Místek</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-placeholder="true">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">
            Stavěli nám hrubou stavbu rodinného domu. Pracovalo se každý den, nemuseli jsme
            nikoho honit. Konečně firma, na kterou je spoleh.
          </p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">JK</div>
            <div>
              <p class="testimonial-name">Jan K.</p>
              <p class="testimonial-role">Brušperk</p>
            </div>
          </div>
        </div>
      </div>
      <div class="testimonials-cta">
        <a href="/recenze" class="btn btn-outline">Zobrazit reference</a>
      </div>
    </div>
  </section>

  <!-- ── FINÁLNÍ CTA ───────────────────────────────────── -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-block">
        <h2>Plánujete stavbu nebo rekonstrukci?</h2>
        <p>
          Přijedeme se podívat, v klidu probereme, co potřebujete, a řekneme vám, jak by to šlo.
          Nezávazně a zdarma.
        </p>
        <div class="cta-actions">
          <a href="/kontakt" class="btn btn-primary cta-btn">Nezávazná poptávka</a>
          <a href="/kontakt" class="btn btn-outline">Kontaktovat</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: calc(100svh - 68px);
  display: grid;
  place-items: center;
  padding-block: 7rem;
  overflow: hidden;
  background-image:
    linear-gradient(rgba(20, 33, 61, 0.82), rgba(20, 33, 61, 0.90)),
    url('/images/hero-kitchen-background.webp');
  background-size: cover;
  background-position: center;
}

.hero-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-content {
  max-width: 860px;
  margin-inline: auto;
  text-align: center;
}

.hero-eyebrow {
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.82);
  margin-bottom: 1.25rem;
}

.hero-content h1 {
  color: white;
  margin-bottom: 1.5rem;
  text-wrap: balance;
  text-shadow: 0 12px 42px rgba(0, 0, 0, 0.28);
}

.hero-sub {
  font-size: 1.125rem;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.86);
  max-width: 62ch;
  margin: 0 auto 2.5rem;
  text-shadow: 0 8px 32px rgba(0, 0, 0, 0.24);
}

.hero-ctas {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.hero-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.14);
}

.hero-trust-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: rgba(255, 255, 255, 0.72);
}

.hero-trust-item svg {
  color: var(--color-secondary);
  flex-shrink: 0;
}

.hero-trust-sep {
  display: block;
  width: 1px;
  height: 14px;
  background-color: rgba(255, 255, 255, 0.18);
}

.hero .btn-primary {
  background-color: white;
  border-color: white;
  color: var(--color-primary);
}

.hero .btn-primary:hover {
  background-color: rgba(255, 255, 255, 0.92);
  border-color: rgba(255, 255, 255, 0.92);
}

.hero .btn-outline {
  background-color: rgba(255, 255, 255, 0.10);
  backdrop-filter: blur(14px) saturate(1.4);
  -webkit-backdrop-filter: blur(14px) saturate(1.4);
  border-color: rgba(255, 255, 255, 0.38);
  color: white;
}

.hero .btn-outline:hover {
  background-color: rgba(255, 255, 255, 0.20);
  border-color: rgba(255, 255, 255, 0.55);
}

.site-photo {
  display: block;
  width: 100%;
  object-fit: cover;
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
}

/* ── Kdo jsme ─────────────────────────────────────────── */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
}

.about-images {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.about-img {
  border-radius: 18px;
}

.about-img--big {
  aspect-ratio: 4/3;
}

.about-img--small {
  aspect-ratio: 16/7;
}

.about-content h2 {
  margin-bottom: 1.25rem;
}

.about-content p {
  line-height: 1.75;
}

.about-stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.about-stat {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.about-stat-num {
  font-family: var(--font-heading);
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.about-stat-label {
  font-size: 0.8125rem;
  color: var(--color-text-muted);
}

/* ── Služby grid podle reference ─────────────────────── */
.services-section {
  background-color: #f3f7fb;
}

.section-top {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 2rem;
  margin-bottom: 4rem;
}

.section-kicker {
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: 0.75rem;
}

.section-top h2 {
  max-width: 10ch;
}

.section-top h2 span,
.mission-card h3 span {
  color: var(--color-secondary);
}

.section-link,
.mission-link,
.service-link {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary);
  transition: gap var(--transition), color var(--transition);
}

.section-link:hover,
.mission-link:hover,
.service-link:hover {
  gap: 0.625rem;
  color: var(--color-secondary);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rem 3rem;
}

.service-card {
  min-height: 172px;
  padding-left: 2rem;
  border-left: 1px solid rgba(20, 33, 61, 0.14);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.service-number {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--color-secondary);
  margin-bottom: 0.8rem;
}

.service-card h3 {
  font-size: clamp(1.3rem, 2vw, 1.75rem);
  max-width: 11ch;
  margin-bottom: 0.75rem;
}

.service-card p {
  font-size: 0.875rem;
  line-height: 1.55;
  max-width: 28ch;
  margin-bottom: 1rem;
}


.mission-panel {
  position: relative;
  margin-top: 6rem;
  min-height: 430px;
  border-radius: 22px;
  overflow: hidden;
  background-image: linear-gradient(90deg, rgba(20,33,61,0.08), rgba(20,33,61,0.22)), url('/images/service-novostavby.webp');
  background-size: cover;
  background-position: center;
}

.mission-image {
  display: none;
}

.mission-card {
  position: absolute;
  left: 2rem;
  bottom: 2rem;
  width: min(520px, calc(100% - 4rem));
  padding: 2.25rem;
  background-color: #fff;
  border-radius: 18px;
  box-shadow: 0 24px 60px rgba(20, 33, 61, 0.18);
}

.mission-card h3 {
  font-size: clamp(1.7rem, 3vw, 2.35rem);
  margin-bottom: 1rem;
}

.mission-card p:not(.section-kicker) {
  font-size: 0.95rem;
  max-width: 52ch;
