<script>
  (() => {
    const carousel = document.querySelector<HTMLElement>('.reviews-carousel');
    const track = carousel?.querySelector<HTMLElement>('.reviews-carousel__track');
    if (!carousel || !track) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const AUTO = 0.04;

    let half = track.scrollWidth / 2;
    let x = 0;
    let vel = 0;
    let hover = false;
    let dragging = false;
    let pointerId: number | null = null;
    let lastClientX = 0;
    let lastMoveT = 0;
    let moved = 0;
    let lastT = 0;

    const recompute = () => { const h = track.scrollWidth / 2; if (h > 0) half = h; };
    recompute();
    window.addEventListener('load', recompute);
    window.addEventListener('resize', recompute);
    if ('ResizeObserver' in window) new ResizeObserver(recompute).observe(track);

    const norm = () => { if (half <= 0) return; x %= half; if (x < 0) x += half; };
    const apply = () => { track.style.transform = `translate3d(${-x}px,0,0)`; };

    const frame = (t: number) => {
      const dt = Math.min(t - lastT, 50);
      lastT = t;
      if (!dragging) {
        if (Math.abs(vel) > 0.003) {
          x += vel * dt;
          vel *= Math.pow(0.94, dt / 16);
        } else {
          vel = 0;
          if (!reduce && !hover) x += AUTO * dt;
        }
      }
      norm();
      apply();
      requestAnimationFrame(frame);
    };
    requestAnimationFrame((t) => { lastT = t; frame(t); });

    carousel.addEventListener('mouseenter', () => { hover = true; });
    carousel.addEventListener('mouseleave', () => { hover = false; });
    carousel.addEventListener('dragstart', (e) => e.preventDefault());

    carousel.addEventListener('pointerdown', (e) => {
      dragging = true;
      vel = 0;
      moved = 0;
      pointerId = e.pointerId;
      lastClientX = e.clientX;
      lastMoveT = e.timeStamp;
      carousel.classList.add('is-grabbing');
      try { carousel.setPointerCapture(e.pointerId); } catch {}
    });

    carousel.addEventListener('pointermove', (e) => {
      if (!dragging || e.pointerId !== pointerId) return;
      const dx = e.clientX - lastClientX;
      const dt = e.timeStamp - lastMoveT || 16;
      lastClientX = e.clientX;
      lastMoveT = e.timeStamp;
      moved += Math.abs(dx);
      x -= dx;
      vel = vel * 0.7 + (-dx / dt) * 0.3;
      norm();
      apply();
      if (moved > 8 && e.cancelable) e.preventDefault();
    });

    const end = (e: PointerEvent) => {
      if (!dragging || e.pointerId !== pointerId) return;
      dragging = false;
      pointerId = null;
      vel = Math.max(-2.5, Math.min(2.5, vel));
      carousel.classList.remove('is-grabbing');
      try { carousel.releasePointerCapture(e.pointerId); } catch {}
    };
    carousel.addEventListener('pointerup', end);
    carousel.addEventListener('pointercancel', end);

    carousel.addEventListener('click', (e) => {
      if (moved > 8) { e.preventDefault(); e.stopPropagation(); }
    }, true);
  })();
</script>
