</style>

<script>
  /* ── Galerie lightbox ──────────────────────────────────── */
  (() => {
    const images = [
      { src: '/images/real-koupelna-mramor.jpg', alt: 'Koupelna s mramorovým obkladem' },
      { src: '/images/real-kuchyn-bila.jpg', alt: 'Bílá kuchyňská linka' },
      { src: '/images/real-kuchyn-led.jpg', alt: 'Kuchyně s LED osvětlením' },
      { src: '/images/real-koupelna-tmava.jpg', alt: 'Moderní tmavá koupelna' },
      { src: '/images/real-kuchyn-modra.jpg', alt: 'Kuchyně v šedé barvě' },
      { src: '/images/real-chodba-bila.jpg', alt: 'Dokončená chodba' },
    ];

    const lb = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbClose = document.getElementById('lightbox-close') as HTMLButtonElement;
    const lbPrev = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const lbNext = document.getElementById('lightbox-next') as HTMLButtonElement;
    if (!lb || !lbImg) return;

    let current = 0;

    const show = (i: number) => {
      current = ((i % images.length) + images.length) % images.length;
      lbImg.src = images[current].src;
      lbImg.alt = images[current].alt;
      lb.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      lbClose.focus();
    };

    const close = () => {
      lb.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };

    document.querySelectorAll<HTMLButtonElement>('.gallery-thumb-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.index ?? '0', 10);
        show(i);
      });
    });

    lbClose.addEventListener('click', close);
    lbPrev.addEventListener('click', () => show(current - 1));
    lbNext.addEventListener('click', () => show(current + 1));

    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.hasAttribute('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();

  /* ── Reviews carousel ─────────────────────────────────── */
  (() => {
    const carousel = document.querySelector<HTMLElement>('.reviews-carousel');
    const track = carousel?.querySelector<HTMLElement>('.reviews-carousel__track');
    if (!carousel || !track) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const AUTO = 0.04;

    let half = track.scrollWidth / 2;
    let x = 0;
    let vel = 0;
    let hover = false;
    let dragging = false;
    let pointerId: number | null = null;
    let lastClientX = 0;
    let lastMoveT = 0;
    let moved = 0;
    let lastT = 0;

    const recompute = () => { const h = track.scrollWidth / 2; if (h > 0) half = h; };
    recompute();
    window.addEventListener('load', recompute);
    window.addEventListener('resize', recompute);

    const wrap = () => {
      if (x <= -half) x += half;
      if (x > 0) x -= half;
    };

    const tick = (t: number) => {
      const dt = Math.min(t - lastT, 64);
      lastT = t;
      if (!reduce) {
        if (!hover && !dragging) vel = -AUTO;
        if (!dragging) {
          vel *= 0.88;
          if (!hover) vel = vel * 0.88 + (-AUTO) * 0.12;
        } else {
          vel *= 0.92;
        }
        x += vel * dt;
        wrap();
        track.style.transform = `translateX(${x}px)`;
      }
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);

    carousel.addEventListener('mouseenter', () => hover = true);
    carousel.addEventListener('mouseleave', () => hover = false);

    carousel.addEventListener('pointerdown', (e) => {
      if (pointerId !== null) return;
      pointerId = e.pointerId;
      carousel.setPointerCapture(e.pointerId);
      dragging = true;
      lastClientX = e.clientX;
      lastMoveT = performance.now();
      moved = 0;
      vel = 0;
      carousel.classList.add('is-grabbing');
    });

    carousel.addEventListener('pointermove', (e) => {
      if (e.pointerId !== pointerId) return;
      const dx = e.clientX - lastClientX;
      const dt = performance.now() - lastMoveT;
      vel = dt > 0 ? dx / dt : 0;
      x += dx;
      wrap();
      track.style.transform = `translateX(${x}px)`;
      lastClientX = e.clientX;
      lastMoveT = performance.now();
      moved += Math.abs(dx);
    });

    const endDrag = (e: PointerEvent) => {
      if (e.pointerId !== pointerId) return;
      pointerId = null;
      dragging = false;
      carousel.classList.remove('is-grabbing');
    };
    carousel.addEventListener('pointerup', endDrag);
    carousel.addEventListener('pointercancel', endDrag);
  })();
</script>
