---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import imgKuchyn1   from '../assets/images/service-novostavby-kuchyn.jpg';
import imgKuchyn2   from '../assets/images/real-kuchyn-bila.jpg';
import imgKuchyn3   from '../assets/images/real-kuchyn-led.jpg';
import imgKuchyn4   from '../assets/images/real-kuchyn-modra.jpg';
import imgKoup1     from '../assets/images/real-koupelna-mramor.jpg';
import imgKoup2     from '../assets/images/real-koupelna-tmava.jpg';
import imgKoup3     from '../assets/images/real-koupelna-zrcadlo.jpg';
import imgKoup4     from '../assets/images/service-rekonstrukce-koupelna.jpg';
import imgChodba1   from '../assets/images/real-chodba-bila.jpg';
import imgChodba2   from '../assets/images/real-chodba-drevo.jpg';
import imgPergola1  from '../assets/images/service-dilci-pergola.jpg';
import imgPergola2  from '../assets/images/real-carport-hory.jpg';

const photos = [
  { src: imgKuchyn1,  alt: 'Kuchyňská linka v novostavbě',        cat: 'kuchyne' },
  { src: imgKuchyn2,  alt: 'Bílá kuchyňská linka',                cat: 'kuchyne' },
  { src: imgKuchyn3,  alt: 'Kuchyně s LED osvětlením',             cat: 'kuchyne' },
  { src: imgKuchyn4,  alt: 'Kuchyně v tmavě šedé',                cat: 'kuchyne' },
  { src: imgKoup1,    alt: 'Koupelna s mramorovým obkladem',       cat: 'koupelna' },
  { src: imgKoup2,    alt: 'Moderní tmavá koupelna',               cat: 'koupelna' },
  { src: imgKoup3,    alt: 'Koupelna se zrcadlem',                 cat: 'koupelna' },
  { src: imgKoup4,    alt: 'Rekonstruovaná koupelna',              cat: 'koupelna' },
  { src: imgChodba1,  alt: 'Bílá chodba po rekonstrukci',          cat: 'chodby' },
  { src: imgChodba2,  alt: 'Chodba s dřevěnými prvky',             cat: 'chodby' },
  { src: imgPergola1, alt: 'Dřevěná pergola na míru',              cat: 'pergoly' },
  { src: imgPergola2, alt: 'Carport s výhledem na hory',           cat: 'pergoly' },
];

const filters = [
  { key: 'vse',      label: 'Vše' },
  { key: 'kuchyne',  label: 'Kuchyně' },
  { key: 'koupelna', label: 'Koupelna' },
  { key: 'chodby',   label: 'Chodby' },
  { key: 'pergoly',  label: 'Pergoly' },
];
---

<Layout
  title="Galerie"
  description="Výběr z dokončených zakázek Merlin Stavby — kuchyně, koupelny, chodby i venkovní stavební práce."
>
  <Nav slot="header" />

  <section class="page-intro">
    <div class="container page-intro__grid">
      <div>
        <nav class="breadcrumb" aria-label="Drobečková navigace">
          <a href="/">Domů</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Galerie</span>
        </nav>
        <p class="page-kicker">Realizace</p>
        <h1>Jak naše práce <span>vypadá v praxi</span></h1>
      </div>
      <p class="page-intro__lead">
        Výběr z dokončených zakázek. Každou stavbu průběžně fotíme — nejen pro sebe, ale hlavně pro vás.
      </p>
    </div>
  </section>

  <section class="section section--large">
    <div class="container">

      <div class="gallery-filters" role="tablist" aria-label="Filtrovat galerii">
        {filters.map((f, i) => (
          <button
            class:list={['filter-btn', { 'filter-btn--active': i === 0 }]}
            data-filter={f.key}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {f.label}
          </button>
        ))}
      </div>

      <div class="gallery-grid" id="gallery-grid">
        {photos.map((photo, i) => (
          <button
            class="gallery-item"
            data-cat={photo.cat}
            data-index={i}
            aria-label={`Zobrazit: ${photo.alt}`}
          >
            <Image
              src={photo.src}
              alt={photo.alt}
              width={600}
              format="webp"
              quality={75}
              loading={i < 6 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </button>
        ))}
      </div>

      <p class="gallery-empty" id="gallery-empty" hidden>Žádné fotky v této kategorii.</p>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Foto" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Zavřít">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="lightbox-inner">
      <button class="lightbox-arrow lightbox-prev" id="lightbox-prev" aria-label="Předchozí">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      <button class="lightbox-arrow lightbox-next" id="lightbox-next" aria-label="Další">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <section class="section section--compact gallery-cta-section">
    <div class="container cta-card">
      <p class="page-kicker">Máte zájem o konkrétní typ práce?</p>
      <h2>Napište nám, pošleme fotky přímo ze zakázek.</h2>
      <a href="/kontakt" class="btn btn-primary">Kontaktovat nás</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ── Filtry ───────────────────────────────────────────────── */
.gallery-filters {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.filter-btn {
  padding: 0.5rem 1.125rem;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 600;
  border: 1px solid var(--color-border);
  border-radius: 999px;
  background: transparent;
  color: var(--color-text-muted);
  cursor: pointer;
  /* bez hover state — záměrně */
  transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
}

.filter-btn--active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: white;
}

/* ── Grid ─────────────────────────────────────────────────── */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.gallery-item {
  all: unset;
  display: block;
  cursor: pointer;
  border-radius: 14px;
  overflow: hidden;
}

.gallery-item[hidden] {
  display: none;
}

.gallery-item img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  display: block;
  transition: transform 400ms cubic-bezier(0.23, 1, 0.32, 1);
}

@media (hover: hover) and (pointer: fine) {
  .gallery-item:hover img {
    transform: scale(1.03);
  }
}

.gallery-empty {
  text-align: center;
  padding: 4rem 0;
  color: var(--color-text-muted);
}

/* ── Lightbox ─────────────────────────────────────────────── */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background-color: rgba(7, 20, 38, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.lightbox[hidden] { display: none; }

.lightbox-close {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  background: rgba(255,255,255,0.12);
  border: none;
  color: white;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color 150ms ease;
}

.lightbox-close:hover { background: rgba(255,255,255,0.22); }

.lightbox-inner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  max-height: 90vh;
}

.lightbox-img {
  max-height: 88vh;
  max-width: calc(100vw - 10rem);
  object-fit: contain;
  border-radius: 8px;
  display: block;
}

.lightbox-arrow {
  flex-shrink: 0;
  background: rgba(255,255,255,0.14);
  border: none;
  color: white;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color 150ms ease;
}

.lightbox-arrow:hover { background: rgba(255,255,255,0.26); }

/* ── CTA ──────────────────────────────────────────────────── */
.gallery-cta-section {
  background-color: var(--color-surface);
  border-top: 1px solid var(--color-border);
}

.cta-card {
  text-align: center;
}

.cta-card h2 {
  max-width: 600px;
  margin: 0.5rem auto 1.75rem;
}

/* ── Responsive ───────────────────────────────────────────── */
@media (max-width: 860px) {
  .gallery-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 520px) {
  .gallery-grid { grid-template-columns: 1fr; }
  .lightbox-inner { gap: 0.375rem; }
  .lightbox-img { max-width: calc(100vw - 7rem); }
  .lightbox-arrow { width: 40px; height: 40px; }
}
</style>

<script>
  (() => {
    const lb        = document.getElementById('lightbox') as HTMLElement;
    const lbImg     = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbClose   = document.getElementById('lightbox-close') as HTMLButtonElement;
    const lbPrev    = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const lbNext    = document.getElementById('lightbox-next') as HTMLButtonElement;
    const emptyMsg  = document.getElementById('gallery-empty') as HTMLElement;
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items      = document.querySelectorAll<HTMLButtonElement>('.gallery-item');

    /* src/alt čteme přímo z vyrenderovaného <img> — optimalizovaný WebP URL */
    const getPhoto = (btn: HTMLButtonElement) => {
      const img = btn.querySelector('img')!;
      return { src: img.src, alt: img.alt };
    };

    let visibleItems: HTMLButtonElement[] = Array.from(items);
    let current = 0;

    /* ── Lightbox ── */
    const openLightbox = (btn: HTMLButtonElement) => {
      current = visibleItems.indexOf(btn);
      if (current < 0) current = 0;
      const { src, alt } = getPhoto(visibleItems[current]);
      lbImg.src = src;
      lbImg.alt = alt;
      lb.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lb.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };

    const navigate = (dir: number) => {
      if (!visibleItems.length) return;
      current = ((current + dir) % visibleItems.length + visibleItems.length) % visibleItems.length;
      const { src, alt } = getPhoto(visibleItems[current]);
      lbImg.src = src;
      lbImg.alt = alt;
    };

    items.forEach((btn) => {
      btn.addEventListener('click', () => openLightbox(btn));
    });

    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => navigate(-1));
    lbNext.addEventListener('click', () => navigate(1));
    lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });

    document.addEventListener('keydown', (e) => {
      if (lb.hasAttribute('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });

    /* ── Filtry s WAAPI reveal animací ── */
    const EASING = 'cubic-bezier(0.23, 1, 0.32, 1)';

    const applyFilter = (filter: string) => {
      visibleItems = [];
      let stagger = 0;

      items.forEach((item) => {
        const cat = item.dataset.cat ?? '';
        const visible = filter === 'vse' || cat === filter;

        if (!visible) {
          item.hidden = true;
        } else {
          item.hidden = false;
          visibleItems.push(item);

          item.animate(
            [
              { opacity: '0', transform: 'translateY(10px)' },
              { opacity: '1', transform: 'translateY(0)' },
            ],
            {
              duration: 260,
              delay: stagger,
              easing: EASING,
              fill: 'both',
            }
          );
          stagger += 35;
        }
      });

      emptyMsg.hidden = visibleItems.length > 0;
    };

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'vse';

        filterBtns.forEach((b) => {
          b.classList.remove('filter-btn--active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('filter-btn--active');
        btn.setAttribute('aria-selected', 'true');

        applyFilter(filter);
      });
    });

    /* Počáteční reveal při načtení stránky */
    applyFilter('vse');
  })();
</script>
