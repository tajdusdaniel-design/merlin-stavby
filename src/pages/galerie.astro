---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const galleryImages = [
  { src: '/images/gallery-kuchyn-svetla.webp', alt: 'Světlá kuchyň po rekonstrukci' },
  { src: '/images/gallery-kuchyn-bila.webp', alt: 'Bílá kuchyňská linka po dokončení' },
  { src: '/images/gallery-koupelna-sprcha.webp', alt: 'Koupelna se sprchovým koutem' },
  { src: '/images/gallery-koupelna-stresni.webp', alt: 'Rekonstrukce koupelny v podkroví' },
  { src: '/images/gallery-chodba.webp', alt: 'Dokončená chodba v interiéru' },
  { src: '/images/gallery-kuchyn-seda.webp', alt: 'Šedá kuchyň po rekonstrukci' },
  { src: '/images/service-rekonstrukce.webp', alt: 'Detail koupelny po rekonstrukci' },
  { src: '/images/about-stavba.webp', alt: 'Venkovní stavební práce u domu' },
  { src: '/images/service-dilci.webp', alt: 'Dokončený přístřešek u domu' },
];
---

<Layout
  title="Galerie"
  description="Výběr z dokončených i rozpracovaných zakázek Merlin Stavby."
>
  <Nav slot="header" />

  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Drobečková navigace">
        <a href="/">Domů</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Galerie</span>
      </nav>

      <div class="section__header">
        <h1>Naše práce</h1>
        <p class="section__lead">
          Výběr z dokončených i rozpracovaných zakázek. Část fotek pravidelně přidáváme
          i na <a href="https://www.instagram.com/merlinstavby" target="_blank" rel="noopener" class="inline-link">Instagram</a>
          a <a href="https://www.facebook.com/merlinstavbysro" target="_blank" rel="noopener" class="inline-link">Facebook</a>.
        </p>
      </div>

      <div class="gallery-grid">
        {galleryImages.map((image) => (
          <img src={image.src} alt={image.alt} class="gallery-item" loading="eager" decoding="async" />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container cta-block">
      <h2>Chcete vidět konkrétní typ práce?</h2>
      <p>Napište nám, co vás zajímá — pošleme vám fotky přímo ze zakázek.</p>
      <a href="/kontakt" class="btn btn-primary" style="margin-top:1.5rem;">Kontaktovat nás</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.gallery-item {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  border: 1px solid var(--color-border);
  border-radius: 18px;
  cursor: pointer;
  transition: opacity var(--transition);
}

.gallery-item:hover {
  opacity: 0.85;
}

.inline-link {
  color: var(--color-accent);
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.cta-block {
  max-width: 600px;
  margin-inline: auto;
  text-align: center;
}

.cta-block h2 { margin-bottom: 0.75rem; }
.cta-block p { font-size: 1.0625rem; }

@media (max-width: 768px) {
  .gallery-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .gallery-grid {
    grid-template-columns: 1fr;
  }
}
</style>
