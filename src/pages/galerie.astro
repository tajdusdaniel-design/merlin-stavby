---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const galleryImages = [
  { src: '/images/gallery-kuchyn-svetla.webp', alt: 'Světlá kuchyň po rekonstrukci' },
  { src: '/images/gallery-kuchyn-bila.webp', alt: 'Bílá kuchyňská linka po dokončení' },
  { src: '/images/gallery-koupelna-sprcha.webp', alt: 'Koupelna se sprchovým koutem' },
  { src: '/images/gallery-koupelna-stresni.webp', alt: 'Rekonstrukce koupelny v podkroví' },
  { src: '/images/gallery-chodba.webp', alt: 'Dokončená chodba v interiéru' },
  { src: '/images/gallery-kuchyn-seda.webp', alt: 'Šedá kuchyň po rekonstrukci' },
  { src: '/images/service-rekonstrukce.webp', alt: 'Detail koupelny po rekonstrukci' },
  { src: '/images/about-stavba.webp', alt: 'Venkovní stavební práce u domu' },
  { src: '/images/service-dilci.webp', alt: 'Dokončený přístřešek u domu' },
];
---

<Layout
  title="Galerie"
  description="Výběr z dokončených i rozpracovaných zakázek Merlin Stavby."
>
  <Nav slot="header" />

  <section class="page-intro">
    <div class="container page-intro__grid">
      <div>
        <nav class="breadcrumb" aria-label="Drobečková navigace">
          <a href="/">Domů</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Galerie</span>
        </nav>
        <p class="page-kicker">Realizace</p>
        <h1>Jak naše práce <span>vypadá v praxi</span></h1>
      </div>
      <p class="page-intro__lead">
        Výběr z dokončených i rozpracovaných zakázek. Část fotek průběžně přidáváme na Instagram a Facebook, aby bylo vidět, že se na stavbě opravdu pracuje.
      </p>
    </div>
  </section>

  <section class="section section--large">
    <div class="container">
      <div class="gallery-grid">
        {galleryImages.map((image, index) => (
          <img src={image.src} alt={image.alt} class:list={['gallery-item', { 'gallery-item--wide': index === 0 || index === 5 }]} loading="eager" decoding="async" />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--compact gallery-cta-section">
    <div class="container cta-card">
      <p class="page-kicker">Chcete vidět konkrétní typ práce?</p>
      <h2>Napište nám, co vás zajímá. Pošleme fotky přímo ze zakázek.</h2>
      <a href="/kontakt" class="btn btn-primary">Kontaktovat nás</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.gallery-item {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  border: 1px solid var(--color-border);
  border-radius: 18px;
  transition: opacity var(--transition);
}

.gallery-item:hover {
  opacity: 0.9;
}

.gallery-item--wide {
  grid-column: span 2;
}

.gallery-cta-section {
  background-color: var(--color-surface);
}

.cta-card {
  text-align: center;
}

.cta-card h2 {
  max-width: 720px;
  margin: 0 auto 1.75rem;
}

@media (max-width: 800px) {
  .gallery-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .gallery-item--wide {
    grid-column: span 1;
  }
}

@media (max-width: 520px) {
  .gallery-grid {
    grid-template-columns: 1fr;
  }
}
</style>
