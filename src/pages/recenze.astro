---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Recenze"
  description="Reference od zákazníků Merlin Stavby."
>
  <Nav slot="header" />

  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Drobečková navigace">
        <a href="/">Domů</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Recenze</span>
      </nav>

      <div class="section__header">
        <h1>Recenze</h1>
        <p class="section__lead">
          Recenze teprve sbíráme. Jakmile budeme mít první ověřená hodnocení od zákazníků,
          najdete je tady.
        </p>
      </div>

      <div class="testimonials-grid">
        <div class="testimonial-card" data-placeholder="true">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">
            Rekonstrukci bytu 3+1 zvládli přesně v termínu, na kterém jsme se domluvili.
            Co mě nejvíc překvapilo — celou dobu jsem věděl, v jaké fázi jsme, protože nám
            pravidelně posílali fotky. Žádné hádání, kdy přijdou.
          </p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">PH</div>
            <div>
              <p class="testimonial-name">Petr H.</p>
              <p class="testimonial-role">Ostrava</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-placeholder="true">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">
            Hledali jsme firmu na celou rekonstrukci domu a báli jsme se, že to bude boj.
            Nakonec úplný opak. Domluva platila, cena se nezměnila a když jsme něco potřebovali
            doladit i po předání, vyřešili to bez řečí.
          </p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">LT</div>
            <div>
              <p class="testimonial-name">Lucie a Tomáš M.</p>
              <p class="testimonial-role">Frýdek-Místek</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-placeholder="true">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <p class="testimonial-text">
            Stavěli nám hrubou stavbu rodinného domu. Pracovalo se každý den, nemuseli jsme
            nikoho honit. Konečně firma, na kterou je spoleh.
          </p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">JK</div>
            <div>
              <p class="testimonial-name">Jan K.</p>
              <p class="testimonial-role">Brušperk</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.testimonial-card {
  background-color: var(--color-testimonial-bg);
  color: var(--color-testimonial-text);
  border-radius: var(--radius-lg);
  padding: 2rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.testimonial-quote {
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  color: var(--color-baby-blue);
  line-height: 1;
  opacity: 0.6;
}

.testimonial-text {
  color: rgba(255,255,255,0.85);
  font-size: 0.9375rem;
  line-height: 1.65;
  flex: 1;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255,255,255,0.12);
}

.testimonial-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 600;
  flex-shrink: 0;
}

.testimonial-name {
  font-weight: 600;
  font-size: 0.9375rem;
  color: white;
}

.testimonial-role {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.55);
}

@media (max-width: 900px) {
  .testimonials-grid {
    grid-template-columns: 1fr;
  }
}
</style>
