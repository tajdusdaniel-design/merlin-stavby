---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';

import imgNovostavby  from '../../assets/images/service-novostavby-kuchyn.jpg';
import imgRekonstrukce from '../../assets/images/service-rekonstrukce-koupelna.jpg';
import imgDilci       from '../../assets/images/service-dilci-pergola.jpg';
---

<Layout
  title="Služby"
  description="Postavíme nový dům, zrekonstruujeme ten stávající, nebo vyřešíme jednu konkrétní práci."
>
  <Nav slot="header" />

  <section class="page-intro">
    <div class="container page-intro__grid">
      <div>
        <nav class="breadcrumb" aria-label="Drobečková navigace">
          <a href="/">Domů</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Služby</span>
        </nav>
        <p class="page-kicker">Naše služby</p>
        <h1>Stavební práce <span>bez hlídání řemeslníků</span></h1>
      </div>
      <p class="page-intro__lead">
        Postavíme nový dům, zrekonstruujeme ten stávající, nebo vyřešíme jednu konkrétní práci.
        Vždy tak, abyste věděli, co se děje, kdy bude hotovo a co to stojí.
      </p>
    </div>
  </section>

  <!-- ── NOVOSTAVBY ─────────────────────────────────────── -->
  <section class="section service-section" id="novostavby">
    <div class="container service-grid">
      <div class="service-content">
        <span class="service-number">01</span>
        <h2>Novostavby</h2>
        <p class="service-lead">
          Postavíme váš dům na klíč, nebo navážeme na fázi, kterou už máte rozjednanou.
          Vy řešíte jednoho dodavatele — my koordinujeme všechno ostatní.
        </p>

        <div class="service-detail">
          <p>
            Pokud stavíte na klíč, zvládneme celou koordinaci za vás — od základové desky přes hrubou stavbu,
            střechu, sádrokartony, rozvody a podlahy, až po finální povrchy a předání klíčů. Pracujeme zděnou
            i dřevostavbovou technologií podle projektu a podle toho, co si vyberete.
            Potřebujete jen navázat na rozjetou fázi? Nasadíme se tam, kde nás potřebujete.
          </p>
        </div>

        <a href="/kontakt?zajem=novostavba" class="btn btn-primary">Poptat novostavbu</a>
      </div>

      <div class="service-visual">
        <Image src={imgNovostavby} alt="Dokončená kuchyně v novostavbě" class="service-img" width={900} format="webp" quality={75} loading="eager" decoding="async" />
        <div class="service-note">
          <p>Pro každého, kdo staví nový rodinný dům a nechce trávit večery koordinací zedníků, elektrikářů a podlahářů.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── REKONSTRUKCE ───────────────────────────────────── -->
  <section class="section service-section service-section--alt" id="rekonstrukce">
    <div class="container service-grid service-grid--reversed">
      <div class="service-visual">
        <Image src={imgRekonstrukce} alt="Zrekonstruovaná koupelna s dřevěnou podlahou" class="service-img" width={900} format="webp" quality={75} loading="lazy" decoding="async" />
        <div class="service-note">
          <p>Pro majitele bytů a rodinných domů, kteří chtějí rekonstrukci s jedním kontaktem po celou dobu.</p>
        </div>
      </div>

      <div class="service-content">
        <span class="service-number">02</span>
        <h2>Rekonstrukce</h2>
        <p class="service-lead">
          Byt nebo dům zrekonstruujeme od demolice po nastěhování. Kompletně,
          nebo jen v té části, která vás trápí.
        </p>

        <div class="service-detail">
          <p>
            Začínáme tam, kde vy chcete — bouráním nebo rovnou stavbou nových příček.
            Uděláme bytové jádro, sádrokartonové konstrukce, omítky i finální stěrky.
            Postaráme se o podlahy, koupelny a všechno, co k rekonstrukci patří.
            Jeden kontakt po celou dobu, harmonogram předem a žádné překvapení na faktuře.
          </p>
        </div>

        <a href="/kontakt?zajem=rekonstrukce" class="btn btn-primary">Poptat rekonstrukci</a>
      </div>
    </div>
  </section>

  <!-- ── DÍLČÍ STAVEBNÍ ČINNOST ─────────────────────────── -->
  <section class="section service-section" id="dilci-prace">
    <div class="container service-grid">
      <div class="service-content">
        <span class="service-number">03</span>
        <h2>Dílčí stavební činnost</h2>
        <p class="service-lead">
          Nemusí jít vždy o celou stavbu. Zvládneme i jednu konkrétní práci —
          pergolu, dlažbu, nebo dodání materiálu bez zbytečně velké zakázky.
        </p>

        <div class="service-detail">
          <h3>Příklady dílčích prací</h3>
          <p>
            Postavíme pergolu nebo přístřešek na auto, položíme zámkovou dlažbu na příjezdovou
            cestu nebo terasu, uděláme venkovní schodiště nebo opěrnou zeď. Pracujeme i na menších
            pracích kolem domu — záleží na tom, co potřebujete.
          </p>
        </div>

        <div class="service-detail">
          <p>
            Postavíme dřevěnou nebo hliníkovou pergolu, přístřešek na auto, položíme zámkovou dlažbu
            na příjezdové cestě nebo terase. Zvládneme venkovní schodiště, opěrné zdi i drobné úpravy
            kolem domu. Nemusí to být velká zakázka — záleží na tom, co konkrétně potřebujete vyřešit.
          </p>
        </div>

        <a href="/kontakt?zajem=dilci-prace" class="btn btn-primary">Poptat dílčí práci</a>
      </div>

      <div class="service-visual">
        <Image src={imgDilci} alt="Dřevěná pergola — dílčí stavební práce" class="service-img" width={900} format="webp" quality={75} loading="lazy" decoding="async" />
        <div class="service-note">
          <p>Pro každého, kdo má kolem domu konkrétní věc k vyřešení a nechce kvůli ní zadávat velkou zakázku.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SPECIALIZACE ───────────────────────────────────── -->
  <section class="section section--medium specs-section">
    <div class="container">
      <div class="specs-head">
        <p class="page-kicker">Specializace</p>
        <h2>Co konkrétně umíme</h2>
        <p class="specs-sub">Konkrétní stavební práce, které navazujeme na celé zakázky i samostatně.</p>
      </div>
      <div class="specs-grid">
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <!-- Základy: vrstvy půdy/betonu -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="15" width="20" height="4" rx="1"/>
              <rect x="4" y="10" width="16" height="4" rx="1"/>
              <rect x="7" y="5" width="10" height="4" rx="1"/>
            </svg>
          </div>
          <h3>Základové desky</h3>
          <p>Příprava základů pro novostavby i přístavby. Přesná výšková úroveň, správná vyztužení a hydroizolace.</p>
        </div>
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <!-- Hrubá stavba: zdi + střecha -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 10.5L12 3l9 7.5"/>
              <path d="M5 10v10h5v-5h4v5h5V10"/>
            </svg>
          </div>
          <h3>Hrubá stavba</h3>
          <p>Zdění, stropy, věnce, překlady. Zděné i dřevostavby — stavíme podle projektu a v termínu.</p>
        </div>
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <!-- Dřevostavby: strom/dřevo -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22V13"/>
              <path d="M6 13h12l-3-5h2L12 2 7 8h2l-3 5z"/>
            </svg>
          </div>
          <h3>Dřevostavby</h3>
          <p>Montovaný dřevěný skelet, OSB opláštění, parotěsné zábrany a zateplení. Rychlá výstavba s přesným harmonogramem.</p>
        </div>
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <!-- Sádrokartony: svislá příčka/panel -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="2" width="6" height="20" rx="1"/>
              <rect x="13" y="2" width="6" height="20" rx="1"/>
              <line x1="11" y1="7" x2="13" y2="7"/>
              <line x1="11" y1="12" x2="13" y2="12"/>
              <line x1="11" y1="17" x2="13" y2="17"/>
            </svg>
          </div>
          <h3>Sádrokartonové práce</h3>
          <p>Příčky, podhledy, šachtové obklady. Přesné spáry, správná kotva, připraveno na všechny povrchy.</p>
        </div>
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <!-- Podlahy: dlaždice/grid -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="9" height="9" rx="1"/>
              <rect x="13" y="2" width="9" height="9" rx="1"/>
              <rect x="2" y="13" width="9" height="9" rx="1"/>
              <rect x="13" y="13" width="9" height="9" rx="1"/>
            </svg>
          </div>
          <h3>Podlahářské práce</h3>
          <p>Příprava podkladu, potěry, lepení dlažby, pokládka plovoucích podlah. Výsledek, který drží a vypadá čistě.</p>
        </div>
        <div class="spec-card">
          <div class="spec-icon" aria-hidden="true">
            <!-- Pergola: horizontální trámy + sloupy -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <line x1="2" y1="7" x2="22" y2="7"/>
              <line x1="5" y1="4" x2="5" y2="7"/>
              <line x1="10" y1="4" x2="10" y2="7"/>
              <line x1="14" y1="4" x2="14" y2="7"/>
              <line x1="19" y1="4" x2="19" y2="7"/>
              <line x1="5" y1="7" x2="5" y2="20"/>
              <line x1="19" y1="7" x2="19" y2="20"/>
              <line x1="5" y1="20" x2="19" y2="20"/>
            </svg>
          </div>
          <h3>Pergoly a dlažby</h3>
          <p>Dřevěné i hliníkové pergoly, přístřešky na auta, zámková dlažba. Venkovní úpravy hotové čistě a pevně.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <section class="section section--compact cta-section-local">
    <div class="container cta-card">
      <p class="page-kicker">Další krok</p>
      <h2>Popište nám, co potřebujete postavit nebo opravit.</h2>
      <a href="/kontakt" class="btn btn-primary">Nezávazná poptávka</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ── Intro ─────────────────────────────────────────────── */
.page-intro {
  padding: 3rem 0 2rem;
  border-bottom: 1px solid var(--color-border);
}

/* ── Service sections ────────────────────────────────── */
.service-section {
  padding: 5rem 0;
  border-bottom: 1px solid var(--color-border);
}

.service-section--alt {
  background-color: var(--color-surface);
}

.service-grid {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 5rem;
  align-items: start;
}

.service-grid--reversed {
  grid-template-columns: 400px 1fr;
}

.service-number {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.875rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  margin-bottom: 0.75rem;
}

.service-content h2 {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  margin-bottom: 1rem;
}

.service-lead {
  font-size: 1.0625rem;
  line-height: 1.7;
  color: var(--color-text-muted);
  margin-bottom: 2rem;
}

.service-detail {
  margin-bottom: 1.75rem;
}

.service-detail h3 {
  font-size: 1.0625rem;
  font-weight: 700;
  margin-bottom: 0.75rem;
  color: var(--color-text-primary);
}

.service-detail p {
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--color-text-secondary);
  margin-bottom: 0.875rem;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 2rem;
  list-style: none;
  padding: 0;
}

.service-list li {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
}

.service-list li::before {
  content: '';
  display: block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: var(--color-accent);
  flex-shrink: 0;
}

.service-img {
  aspect-ratio: 4/3;
  width: 100%;
  object-fit: cover;
  border-radius: var(--radius-lg);
  margin-bottom: 1rem;
  display: block;
}

.service-note {
  padding: 1rem 1.25rem;
  border: 1px solid var(--color-border);
  border-radius: 10px;
}

.service-note p {
  font-size: 0.875rem;
  line-height: 1.6;
  color: var(--color-text-muted);
  margin: 0;
}

/* ── Specializace ────────────────────────────────────── */
.specs-section {
  background-color: var(--color-bg);
}

.specs-head {
  max-width: 600px;
  margin-bottom: 3rem;
}

.specs-head h2 {
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  margin-bottom: 0.75rem;
}

.specs-sub {
  font-size: 1rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.specs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--color-border);
  border-left: 1px solid var(--color-border);
}

.spec-card {
  padding: 2rem;
  border-right: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  transition: background-color 200ms ease;
}

.spec-card:hover {
  background-color: var(--color-surface);
}

.spec-icon {
  color: var(--color-accent);
  margin-bottom: 1.125rem;
}

.spec-card h3 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.spec-card p {
  font-size: 0.875rem;
  line-height: 1.65;
  color: var(--color-text-muted);
}

/* ── CTA ─────────────────────────────────────────────── */
.cta-section-local {
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.cta-card {
  text-align: center;
}

.cta-card h2 {
  max-width: 720px;
  margin: 0.5rem auto 1.75rem;
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 1024px) {
  .service-grid,
  .service-grid--reversed {
    grid-template-columns: 1fr 340px;
    gap: 3.5rem;
  }
}

@media (max-width: 900px) {
  .service-grid,
  .service-grid--reversed {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .service-grid--reversed .service-visual {
    order: -1;
  }

  .specs-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 560px) {
  .specs-grid {
    grid-template-columns: 1fr;
  }
}
</style>
